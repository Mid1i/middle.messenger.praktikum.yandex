{
  "name": "middle.messenger.praktikum.yandex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run typecheck && npm run lint:eslint && npm run lint:styles && npm run format:check",
    "build": "npm run typecheck && vite build",
    "start": "npm run build && vite preview --host 0.0.0.0 --port 3000",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "handlebars": "^4.7.9",
    "sass": "^1.99.0"
  }
}
