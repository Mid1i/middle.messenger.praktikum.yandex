<button class="chats-list-item {{#if isActive}} chats-list-item_active {{/if}}" type="button">
	{{> base-avatar 
		alt="Аватар пользователя {{ last_message.user.first_name }} {{ last_message.user.second_name }}" 
		url="{{ avatar }}" 
	}}
	<div class="chats-list-item__content">
		<span class="chats-list-item__title base-text S">{{ title }}</span>
		<span class="chats-list-item__text base-text XS">
			<span class="chats-list-item__text base-text Bold">{{ last_message.user.first_name }}:</span> 
			{{ last_message.content }}
		</span>
	</div>
	{{#if unread_count}}
		<span 
			class="chats-list-item__counter base-text XS rect-size"
			aria-label="Непрочитанных соощений: {{ unread_count }}"	
		>
			{{ unread_count }}
		</span>
	{{/if}}
</button>